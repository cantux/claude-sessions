#!/usr/bin/env python3
"""List Claude Code sessions with timestamps and opening prompt summaries."""

import json
import os
import sys
from pathlib import Path
from datetime import datetime

SESSIONS_DIR = Path.home() / ".claude" / "projects"

SKIP_PREFIXES = ("<local-command-caveat>", "<local-command-stdout>", "<command-name>", "<command-message>", "# ")


def get_first_user_message(path):
    try:
        with open(path) as f:
            for line in f:
                try:
                    obj = json.loads(line)
                    if obj.get("type") != "user":
                        continue
                    content = obj.get("message", {}).get("content", "")
                    if isinstance(content, list):
                        for c in content:
                            if isinstance(c, dict) and c.get("type") == "text":
                                content = c["text"]
                                break
                        else:
                            content = ""
                    if isinstance(content, str):
                        text = content.strip().replace("\n", " ")
                        if text and not any(text.startswith(p) for p in SKIP_PREFIXES):
                            return text
                except Exception:
                    continue
    except Exception:
        pass
    return "(no user message found)"


def list_sessions(project_filter=None, width=90):
    if not SESSIONS_DIR.exists():
        print(f"No sessions directory found at {SESSIONS_DIR}")
        return

    sessions = []
    for d in SESSIONS_DIR.iterdir():
        if not d.is_dir():
            continue
        if project_filter and project_filter not in d.name:
            continue
        for f in d.glob("*.jsonl"):
            mtime = f.stat().st_mtime
            size_kb = f.stat().st_size // 1024
            sessions.append((mtime, f, d.name, size_kb))

    sessions.sort(key=lambda x: x[0])

    if not sessions:
        print("No sessions found.")
        return

    summary_width = width - 52
    header = f"{'DATE':<18} {'SIZE':>6}  {'PROJECT':<18} {'ID':>10}  SUMMARY"
    print(header)
    print("-" * (len(header) + summary_width))

    for mtime, f, project_name, size_kb in sessions:
        dt = datetime.fromtimestamp(mtime).strftime("%Y-%m-%d %H:%M")
        session_id = f.stem[:8]
        summary = get_first_user_message(f)[:summary_width]
        proj = project_name[:18]
        print(f"{dt:<18} {size_kb:>5}K  {proj:<18} {session_id}  {summary}")

    print(f"\nTotal: {len(sessions)} session(s)")
    print("\nResume: claude --resume <session-id>  |  Browse: claude --resume")


if __name__ == "__main__":
    project_filter = sys.argv[1] if len(sys.argv) > 1 else None
    list_sessions(project_filter)
